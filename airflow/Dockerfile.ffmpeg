FROM apache/airflow:2.7.0-python3.10

# Install ffmpeg so video (.mp4) preprocessing works inside Airflow containers
USER root
RUN apt-get update \
    && apt-get install -y --no-install-recommends ffmpeg \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Switch back to the airflow user (UID is set by AIRFLOW_UID in docker-compose)
USER airflow

